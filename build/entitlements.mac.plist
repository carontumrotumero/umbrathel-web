<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Necesario para Electron (JIT de V8) con hardened runtime -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Micrófono y cámara para chats de voz/vídeo (Discord, Meet…) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <key>com.apple.security.device.camera</key>
    <true/>
    <!-- Passkeys / Touch ID (WebAuthn): requiere app firmada con Team ID -->
    <key>keychain-access-groups</key>
    <array>
      <string>$(TeamIdentifierPrefix)com.umbrathel.web.webauthn</string>
    </array>
  </dict>
</plist>

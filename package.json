{
  "name": "umbrathel-web",
  "productName": "Umbrathel Web",
  "version": "0.3.0",
  "description": "Umbrathel Web — navegador de escritorio construido sobre Chromium (Electron)",
  "main": "src/main/main.js",
  "private": true,
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/carontumrotumero/umbrathel-web.git",
    "github": "carontumrotumero/umbrathel-web"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "com.umbrathel.web",
    "productName": "Umbrathel Web",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "carontumrotumero",
      "repo": "umbrathel-web"
    }
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  }
}
